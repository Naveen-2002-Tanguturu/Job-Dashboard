{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-style": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off",
    "attr-quotes": ["error", { "style": "double" }],
    "no-inline-style": "off",
    "long-title": "off",
    "prefer-native-element": "off",
    "element-required-attributes": "off"
  }
}
